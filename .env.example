# ================================================
# LearnHub — Production Environment Configuration
# ================================================

# Node
NODE_ENV=production

# ── Database (PostgreSQL) ──
DATABASE_URL=postgresql://postgres:CHANGE_ME_STRONG_PASSWORD@localhost:5432/learnhub?schema=public

# ── Redis ──
REDIS_URL=redis://localhost:6379

# ── JWT (MUST change in production!) ──
JWT_SECRET=CHANGE_ME_USE_openssl_rand_-hex_32
JWT_REFRESH_SECRET=CHANGE_ME_USE_openssl_rand_-hex_32
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── API ──
API_PORT=3001
CORS_ORIGIN=https://yourdomain.com

# ── Frontend ──
WEB_PORT=3000
NEXT_PUBLIC_API_URL=https://yourdomain.com/api

# ── AI (Google Gemini) ──
GEMINI_API_KEY=

# ── PostgreSQL (for docker-compose) ──
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=learnhub
